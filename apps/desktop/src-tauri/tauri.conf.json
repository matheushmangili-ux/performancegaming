{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "ClockReaper",
	"version": "0.1.0",
	"identifier": "gg.clockreaper.desktop",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build",
		"devUrl": "http://localhost:1420",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "ClockReaper",
				"width": 1280,
				"height": 800,
				"minWidth": 1024,
				"minHeight": 720,
				"resizable": true,
				"decorations": true,
				"transparent": false,
				"backgroundColor": "#050011"
			}
		],
		"security": {
			"csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["msi", "nsis"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": ["resources/scripts/**/*"],
		"windows": {
			"wix": {
				"language": ["pt-BR", "en-US"]
			},
			"nsis": {
				"installerIcon": "icons/icon.ico",
				"installMode": "perMachine"
			}
		},
		"category": "Utility",
		"shortDescription": "Win11 gaming optimization suite",
		"longDescription": "ClockReaper audita, explica e otimiza seu Windows 11 para gaming com UI cyberpunk e perfis por jogo."
	}
}
