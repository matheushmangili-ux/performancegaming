{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Default capabilities granted to the main window.",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:window:allow-close",
		"core:window:allow-minimize",
		"core:window:allow-start-dragging",
		"core:webview:default",
		"dialog:default",
		"shell:allow-open"
	]
}
